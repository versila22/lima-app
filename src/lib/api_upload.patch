+export async function uploadMyPhoto(memberId: string, file: File): Promise<{ photo_url: string }> {
+  const formData = new FormData();
+  formData.append("file", file);
+  return api.post<{ photo_url: string }>(`/members/${memberId}/photo`, formData, {
+    // Let the browser set Content-Type with the boundary
+    headers: {},
+  });
+}
