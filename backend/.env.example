# Database
DATABASE_URL=postgresql+asyncpg://lima:password@localhost:5432/lima_db

# JWT
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@lima-impro.fr
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=LIMA <noreply@lima-impro.fr>
EMAIL_ENABLED=false

# Railway (auto-populated)
PORT=8000
